# 应用配置
APP_NAME=PVE 虚拟机管理系统
APP_URL=http://localhost
APP_DEBUG=true

# 数据库配置
DB_HOST=db
DB_NAME=pve_manager
DB_USER=root
DB_PASSWORD=rootpass123
DB_CHARSET=utf8mb4

# 支付宝配置
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# 微信支付配置
WECHAT_APPID=
WECHAT_MCH_ID=
WECHAT_API_KEY=

# SMTP邮件配置
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
SMTP_ENCRYPTION=tls

# 安全配置
SESSION_LIFETIME=86400
CSRF_TOKEN_LIFETIME=3600

# PVE配置
PVE_DEFAULT_TIMEOUT=30
PVE_SYNC_INTERVAL=300

# 日志配置
LOG_LEVEL=info
LOG_MAX_DAYS=30

# 速率限制配置
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_TIME_WINDOW=60